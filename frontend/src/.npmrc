# Suppress npm deprecation warnings from transitive dependencies (e.g. ESLint v8's
# transitive deps: glob@7, @humanwhocodes/object-schema@2) so they don't clutter
# deployment logs.  "warn" still shows genuine install problems; "error" only shows
# hard failures.  Set to "error" here so only real errors surface in CI/CD pipelines.
loglevel=error
